{
  "swagger": "2.0",
  "info": {
    "title": "SDP - Assets & CMDB (v3)",
    "description": "Manage ManageEngine ServiceDesk Plus On-Premises assets and the CMDB (v3 JSON API): CI types, configuration items per type and across the CMDB, CI metadata, association relationships, and assets. Auth: technician API key in the 'authtoken' header; every parameter is wrapped in a single 'input_data' JSON envelope. Full CMDB v3 requires SDP build 15100+ (or AssetExplorer 7700+).",
    "version": "0.2.0",
    "contact": {
      "name": "Peter Braun",
      "url": "https://github.com/PBNZ/sdp-on-prem-powerplatform"
    }
  },
  "host": "sdp.example.com",
  "basePath": "/api/v3",
  "schemes": [
    "https"
  ],
  "produces": [
    "application/json"
  ],
  "securityDefinitions": {
    "api_key": {
      "type": "apiKey",
      "in": "header",
      "name": "authtoken"
    }
  },
  "security": [
    {
      "api_key": []
    }
  ],
  "paths": {
    "/ci_types": {
      "get": {
        "operationId": "ListCITypes",
        "summary": "List CI types",
        "description": "Lists all CMDB configuration-item types. Each has an api_plural_name used as the CI Type path segment.",
        "parameters": [
          {
            "name": "input_data",
            "in": "query",
            "type": "string",
            "required": false,
            "x-ms-summary": "Input Data (JSON)",
            "x-ms-visibility": "important",
            "description": "Lists all CMDB configuration-item types. Each has an api_plural_name used as the CI Type path segment. Uses the list_info envelope.",
            "default": "{\"list_info\":{\"row_count\":100,\"start_index\":1,\"get_total_count\":true}}"
          },
          {
            "$ref": "#/parameters/AcceptHeader"
          }
        ],
        "responses": {
          "200": {
            "description": "List CI types returned.",
            "schema": {
              "$ref": "#/definitions/CITypeListEnvelope"
            }
          },
          "default": {
            "description": "SDP error envelope (response_status.status_code != 2000)."
          }
        }
      }
    },
    "/cmdb": {
      "get": {
        "operationId": "ListAllCIs",
        "summary": "List all CIs",
        "description": "Lists all configuration items across every type.",
        "parameters": [
          {
            "name": "input_data",
            "in": "query",
            "type": "string",
            "required": false,
            "x-ms-summary": "Input Data (JSON)",
            "x-ms-visibility": "important",
            "description": "Lists all configuration items across every type. Uses the list_info envelope.",
            "default": "{\"list_info\":{\"row_count\":10,\"start_index\":1,\"get_total_count\":true}}"
          },
          {
            "$ref": "#/parameters/AcceptHeader"
          }
        ],
        "responses": {
          "200": {
            "description": "List all CIs returned.",
            "schema": {
              "$ref": "#/definitions/CIListEnvelope"
            }
          },
          "default": {
            "description": "SDP error envelope (response_status.status_code != 2000)."
          }
        }
      }
    },
    "/{ci_type}": {
      "get": {
        "operationId": "ListCIsByType",
        "summary": "List CIs by type",
        "description": "Lists configuration items of one CI type. Set CI Type to the type's api_plural_name (from List CI types).",
        "parameters": [
          {
            "name": "ci_type",
            "in": "path",
            "type": "string",
            "required": true,
            "x-ms-summary": "CI Type (api_plural_name)",
            "description": "The CI type's api_plural_name, e.g. cmdb_businessservice."
          },
          {
            "name": "input_data",
            "in": "query",
            "type": "string",
            "required": false,
            "x-ms-summary": "Input Data (JSON)",
            "x-ms-visibility": "important",
            "description": "list_info envelope as a JSON string.",
            "default": "{\"list_info\":{\"row_count\":10,\"start_index\":1,\"get_total_count\":true}}"
          },
          {
            "$ref": "#/parameters/AcceptHeader"
          }
        ],
        "responses": {
          "200": {
            "description": "CIs returned.",
            "schema": {
              "$ref": "#/definitions/CIListEnvelope"
            }
          },
          "default": {
            "description": "SDP error envelope (response_status.status_code != 2000)."
          }
        }
      },
      "post": {
        "operationId": "CreateCI",
        "summary": "Create CI",
        "description": "Creates a configuration item of the given type. The input_data payload wraps the CI object; confirm the field set against the type's metadata.",
        "parameters": [
          {
            "name": "ci_type",
            "in": "path",
            "type": "string",
            "required": true,
            "x-ms-summary": "CI Type (api_plural_name)",
            "description": "The CI type's api_plural_name."
          },
          {
            "name": "input_data",
            "in": "formData",
            "type": "string",
            "required": true,
            "x-ms-summary": "Input Data (JSON)",
            "x-ms-visibility": "important",
            "description": "Creates a configuration item of the given type. The input_data payload wraps the CI object; confirm the field set against the type's metadata. Example: {\"ci\":{\"name\":\"web01\",\"ci_type\":{\"name\":\"Business Service\"}}}"
          },
          {
            "$ref": "#/parameters/AcceptHeader"
          }
        ],
        "responses": {
          "201": {
            "description": "Create CI created.",
            "schema": {
              "$ref": "#/definitions/CIEnvelope"
            }
          },
          "200": {
            "description": "Create CI created (builds returning 200).",
            "schema": {
              "$ref": "#/definitions/CIEnvelope"
            }
          },
          "default": {
            "description": "SDP error envelope (response_status.status_code != 2000)."
          }
        },
        "consumes": [
          "application/x-www-form-urlencoded"
        ]
      }
    },
    "/{ci_type}/{ci_id}": {
      "get": {
        "operationId": "GetCI",
        "summary": "Get CI",
        "description": "Gets a single configuration item by type and ID.",
