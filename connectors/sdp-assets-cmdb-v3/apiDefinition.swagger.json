              "$ref": "#/definitions/CIEnvelope"
            }
          },
          "default": {
            "description": "SDP error envelope (response_status.status_code != 2000)."
          }
        }
      },
      "put": {
        "operationId": "UpdateCI",
        "summary": "Update CI",
        "description": "Updates a configuration item by type and ID (V3 updates by CI ID only, no criteria-based update).",
        "parameters": [
          {
            "name": "ci_type",
            "in": "path",
            "type": "string",
            "required": true,
            "x-ms-summary": "CI Type (api_plural_name)",
            "description": "The CI type's api_plural_name."
          },
          {
            "name": "ci_id",
            "in": "path",
            "type": "string",
            "required": true,
            "x-ms-summary": "CI ID",
            "description": "The numeric CI ID."
          },
          {
            "name": "input_data",
            "in": "formData",
            "type": "string",
            "required": true,
            "x-ms-summary": "Input Data (JSON)",
            "x-ms-visibility": "important",
            "description": "CI payload. Example: {\"ci\":{\"name\":\"web01-renamed\"}}"
          },
          {
            "$ref": "#/parameters/AcceptHeader"
          }
        ],
        "responses": {
          "200": {
            "description": "CI updated.",
            "schema": {
              "$ref": "#/definitions/CIEnvelope"
            }
          },
          "default": {
            "description": "SDP error envelope (response_status.status_code != 2000)."
          }
        },
        "consumes": [
          "application/x-www-form-urlencoded"
        ]
