          {
            "name": "ci_id",
            "in": "path",
            "type": "string",
            "required": true,
            "x-ms-summary": "CI ID",
            "description": "The numeric CI ID."
          },
          {
            "$ref": "#/parameters/AcceptHeader"
          }
        ],
        "responses": {
          "200": {
            "description": "CI returned.",
